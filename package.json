{
  "name": "quent-action",
  "version": "1.0.0",
  "description": "GitHub Action to run Quent AI-generated Playwright tests",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "build:cleanup": "ncc build src/cleanup.ts -o dist/cleanup-temp && mv dist/cleanup-temp/index.js dist/cleanup.js && rm -rf dist/cleanup-temp",
    "build:all": "npm run build && npm run build:cleanup",
    "lint": "eslint src/**/*.ts",
    "test": "jest",
    "prepare": "npm run build:all"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/quent-ai/quent-action.git"
  },
  "keywords": [
    "github-action",
    "playwright",
    "testing",
    "ai",
    "qa",
    "automation"
  ],
  "author": "Quent AI",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/exec": "^1.1.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "@actions/tool-cache": "^2.0.1",
    "adm-zip": "^0.5.10",
    "node-fetch": "^3.3.2"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.5",
    "@types/node": "^20.10.0",
    "@vercel/ncc": "^0.38.1",
    "typescript": "^5.3.2"
  }
}

